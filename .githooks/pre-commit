#!/bin/sh
# Enforce the "code metrics must not rise" rule on every commit.
# Fails the commit if tracked Swift code lines or approximate complexity
# grew above scripts/metrics-baseline.json. See AGENTS.md for the policy.
#
# Enable once per clone:  git config core.hooksPath .githooks
#
# Bypass in a true emergency with `git commit --no-verify` (discouraged).

python3 scripts/code_metrics.py --check
status=$?
if [ "$status" -ne 0 ]; then
    echo ""
    echo "Pre-commit blocked by code-metrics guard." 1>&2
fi
exit "$status"
